#!/usr/bin/env bash
#
# Pre-push hook: fmt + clippy + tests.
#
# Same gate as pre-commit — kept as a backstop for commits made with
# `--no-verify` or from clones that enabled hooks after committing.
#
# Enable for this clone:
#   git config core.hooksPath .githooks
#
set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

echo "==> cargo fmt --all --check"
cargo fmt --all --check

echo "==> cargo clippy --all-targets -- -D warnings (too_many_lines suppressed)"
cargo clippy --all-targets -- -D warnings \
    -A clippy::too_many_lines

echo "==> cargo test --all-targets"
cargo test --all-targets --quiet

echo "pre-push OK"
