#!/usr/bin/env bash
#
# Pre-push hook: fmt + clippy across all four feature flags + tests.
#
# This is the *thorough* gate before sharing with the remote (~2-3 min).
# Catches feature-flag-specific clippy warnings the pre-commit hook doesn't.
#
# Enable for this clone:
#   git config core.hooksPath .githooks
#
set -euo pipefail

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

echo "==> cargo fmt --all --check"
cargo fmt --all --check

for feature in mainnet testnet stagenet devnet-amplifier; do
    echo "==> cargo clippy --no-default-features --features $feature --all-targets -- -D warnings (too_many_lines suppressed)"
    cargo clippy --no-default-features --features "$feature" --all-targets -- -D warnings \
        -A clippy::too_many_lines
done

echo "==> cargo test --all-targets"
cargo test --all-targets --quiet

echo "pre-push OK"
