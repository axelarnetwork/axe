# Chain identity
CHAIN=arc-11
ENV=testnet

# Chain metadata
CHAIN_NAME="Arc Testnet"
CHAIN_ID=5042002
RPC_URL=https://rpc.testnet.arc.network
TOKEN_SYMBOL=USDC
DECIMALS=18
EXPLORER_NAME="Arc Testnet Explorer"
EXPLORER_URL="https://testnet.arcscan.app/"

# Axelar config
TARGET_JSON=../axelar-contract-deployments/axelar-chains-config/info/testnet.json
MNEMONIC="..."
MULTISIG_PROVER_MNEMONIC="..."

# Deployment keys
SALT=v1.0.13
DEPLOYER_PRIVATE_KEY=0x...
GATEWAY_DEPLOYER_PRIVATE_KEY=0x...
GAS_SERVICE_DEPLOYER_PRIVATE_KEY=0x...

# ITS (optional — only needed for `axe deploy` ITS steps and `axe test its`)
ITS_DEPLOYER_PRIVATE_KEY=0x...
ITS_SALT=v2.2.0
ITS_PROXY_SALT=v1.0.0

# Alchemy (optional — used by `axe decode tx` for reliable archive RPCs)
# ALCHEMY_TOKEN=your_token_here

# Load-test RPC overrides (optional — equivalent to --source-rpc / --destination-rpc).
# Useful when the chain config's default endpoint is rate-limited or down.
# SOURCE_RPC=https://...
# DESTINATION_RPC=https://...

# Axelar Cosmos LCD/RPC overrides (optional — used by the cross-chain verifier).
# Defaults to the URL from the chains config (often imperator.co), with built-in
# fallbacks to lavenderfive/publicnode/cosmos.directory if those flap.
# AXELAR_LCD_URL=https://rest.lavenderfive.com/axelar
# AXELAR_RPC_URL=https://axelar-rpc.publicnode.com
